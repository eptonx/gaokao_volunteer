spring.application.name=gaokaoproject
server.port=8080

# Database
spring.datasource.url=jdbc:mysql://localhost:3306/gaokao_volunteer?serverTimezone=GMT%2B8&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
spring.datasource.username=your_db_username
spring.datasource.password=your_db_password



logging.level.org.springframework.web.servlet.DispatcherServlet=DEBUG

# MyBatis
mybatis.configuration.map-underscore-to-camel-case=true
logging.level.com.example.gaokaoproject.mapper=debug

# PageHelper
pagehelper.helper-dialect=mysql
pagehelper.reasonable=true

# Session
spring.session.timeout=6h

# Redis
spring.data.redis.host=localhost
spring.data.redis.port=6379
spring.data.redis.password=
spring.data.redis.database=0

#ai
spring.ai.openai.base-url=https://api.deepseek.com
spring.ai.openai.api-key=your_deepseek_api_key
spring.ai.openai.chat.model=deepseek-chat
spring.ai.openai.chat.options.max-tokens=4000
spring.ai.openai.chat.options.temperature=0.7
# JWT
jwt.secret=your_jwt_secret_key
# access token: 30min
jwt.access-expiration=1800000
# refresh token: 7days
jwt.refresh-expiration=604800000

logging.level.com.example.gaokaoproject.controller=DEBUG

spring.sql.init.mode=never
